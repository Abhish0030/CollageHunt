# Core runtime
NODE_ENV="production"
PORT=4000
HOST="0.0.0.0"

# Database
DATABASE_URL="postgresql://postgres.[YOUR-PROJECT]:[YOUR-PASSWORD]@aws-0-[REGION].pooler.supabase.com:5432/postgres?connect_timeout=30"
DIRECT_URL="postgresql://postgres.[YOUR-PROJECT]:[YOUR-PASSWORD]@aws-0-[REGION].pooler.supabase.com:5432/postgres?connect_timeout=30"

# App URLs
BASE_URL="https://your-backend-service.onrender.com"
BACKEND_URL="https://your-backend-service.onrender.com"
RENDER_EXTERNAL_URL="https://your-backend-service.onrender.com"
FRONTEND_URL="https://your-frontend-app.vercel.app"
FRONTEND_ORIGIN="https://your-frontend-app.vercel.app"
CORS_ORIGIN="https://your-frontend-app.vercel.app"

# JWT / session
JWT_SECRET="replace-with-a-strong-jwt-secret"
SESSION_SECRET="replace-with-a-strong-session-secret"
SECRET="replace-with-a-strong-session-secret"

# Auth0
AUTH0_DOMAIN="https://your-auth0-tenant.us.auth0.com"
ISSUER_BASE_URL="https://your-auth0-tenant.us.auth0.com"
AUTH0_CLIENT_ID="your-auth0-client-id"
CLIENT_ID="your-auth0-client-id"
AUTH0_CLIENT_SECRET="your-auth0-client-secret"
CLIENT_SECRET="your-auth0-client-secret"
AUTH0_SECRET="replace-with-a-strong-session-secret"
AUTH0_PUBLIC_BASE_URL="https://your-backend-service.onrender.com"
AUTH0_GOOGLE_CONNECTION="google-oauth2"
AUTH0_GOOGLE_PROMPT="select_account"
AUTH0_HTTP_TIMEOUT=15000

# Notes
# 1. BASE_URL/AUTH0_PUBLIC_BASE_URL must point to the backend service URL because
#    the Auth0 callback route is served by the backend, not the frontend.
# 2. FRONTEND_URL/FRONTEND_ORIGIN/CORS_ORIGIN should point to your Vercel frontend.
# 3. For Render + Supabase, prefer the pooler connection string above.
# 4. DIRECT_URL is used by Prisma migrations and deploy-time commands.
#    If you omit it, the backend start/deploy scripts fall back to DATABASE_URL.
